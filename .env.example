# Anthropic API key — used by the AI Feedback Layer.
# Copy this file to `.env` and paste your real values. `.env` is git-ignored.
ANTHROPIC_API_KEY=your_key_here

# --- Gmail SMTP (password reset emails) ---
# 1. Google Account → Security → 2-Step Verification (on)
# 2. App passwords → create password for "Mail"
# 3. Paste the 16-character app password below (NOT your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=yourname@gmail.com

# Public URL of the app (reset links in emails)
APP_BASE_URL=http://localhost:8501

# Set to true only for local dev to show reset links on screen when email fails
# ADAPTIVPREP_DEV=false
